# ── Database ────────────────────────────────────────────────────────────────
# MySQL / MariaDB connection string
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── Email Provider ───────────────────────────────────────────────────────────
# 'gmail'  → Gmail SMTP via app password
# 'graph'  → Microsoft Graph API (client credentials / application permissions)
# This is the ENV fallback. The Settings panel in the admin overrides it per deployment.
MAIL_PROVIDER="gmail"

# Gmail SMTP (required when MAIL_PROVIDER=gmail)
# Use a Google "App Password", not your regular Gmail password.
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Microsoft Graph (required when MAIL_PROVIDER=graph)
# Requires an Azure app registration with Mail.Send application permission.
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
MS_FROM_EMAIL="noreply@yourdomain.com"
